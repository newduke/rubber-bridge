# Copy this file to .env or .env.local and fill in real values.
# Never commit real secrets.

APP_ENV=development

# Expo public vars are bundled into the client app.
# Do NOT put secrets here.
EXPO_PUBLIC_APP_NAME=Rubber Bridge
EXPO_PUBLIC_APP_SLUG=rubber-bridge
EXPO_PUBLIC_APP_SCHEME=rubber-bridge
EXPO_PUBLIC_ANDROID_ADAPTIVE_ICON_BG=#1b5e20
EXPO_PUBLIC_API_BASE_URL=

# Put real secrets only in private server-side env vars, never in EXPO_PUBLIC_*.
# Example (for backend/server tooling, not for Expo client bundling):
# PRIVATE_API_TOKEN=
