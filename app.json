{
  "expo": {
    "name": "Rubber Bridge",
    "slug": "rubber-bridge",
    "version": "1.0.0",
    "scheme": "rubber-bridge",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "platforms": [
      "ios",
      "android",
      "web"
    ],
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#1b5e20"
      }
    },
    "plugins": [
      "expo-asset"
    ]
  }
}
